# Database — output do fiap-tc-mecanica-infra-db (terraform output rds_*)
DB_HOST=<rds-endpoint>.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mecanica
DB_USER=mecanica_user
DB_PASSWORD=<terraform output -raw rds_master_password>
DB_SSL=true

# JWT — MESMA secret HS256 do app Spring Boot (k8s Secret SECURITY_JWT_SECRET_KEY)
SECURITY_JWT_SECRET_KEY=<base64-encoded-secret-min-256bit>
ACCESS_TOKEN_TTL_SECONDS=3600
